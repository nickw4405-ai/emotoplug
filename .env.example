# ── Required ──────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional (enables live price search) ──────────────────
# Free tier available at: https://brave.com/search/api/
# Without this, Claude uses its training knowledge to suggest mods + links.
# With this, it also searches the live web for real product pages & prices.
BRAVE_API_KEY=BSA...

# ── Server ────────────────────────────────────────────────
PORT=5000
